generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
 
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Institute {
  id        String    @id @default(uuid())
  name      String
  location  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  students  Student[]

  @@index([name])
}

model Student {
  id          String   @id @default(uuid())
  name        String
  instituteId String
  createdAt   DateTime @default(now())

  institute   Institute @relation(fields: [instituteId], references: [id])
  results     Result[]

  @@index([instituteId])
}

model Course {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  results Result[]
}

model Result {
  id        String @id @default(uuid())
  studentId String
  courseId  String
  score     Int
  year      Int
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])

  @@index([studentId])
  @@index([courseId])
  @@index([year])

  @@index([year, courseId]) 
}